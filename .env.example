OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.4-mini

# Supabase (RAG, leads, chat logs) — optional. Without these, the chatbot
# falls back to injecting the full uploads/*.md content, and the consult
# form will return an error since leads can't be saved.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
